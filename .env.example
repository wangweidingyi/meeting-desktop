MEETING_DESKTOP_CLIENT_ID=meeting-desktop-dev

# When running through `npm run dev:local`, these can be omitted if
# `meeting-server/.env` already enables the embedded broker and defines UDP.
MEETING_SERVER_MQTT_BROKER=tcp://127.0.0.1:1883
MEETING_SERVER_MQTT_USERNAME=
MEETING_SERVER_MQTT_PASSWORD=

# Already used by the desktop UDP audio runtime.
MEETING_SERVER_UDP_HOST=127.0.0.1
MEETING_SERVER_UDP_PORT=6000

# macOS development-only helper:
# - leave empty to keep microphone-only passthrough
# - set to mirror_microphone to mirror mic frames into the system track so the
#   dual-source mixed uplink path can be tested locally without native loopback
MEETING_MACOS_DEV_SYSTEM_AUDIO=
