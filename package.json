{
  "name": "meeting",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "node ./scripts/run-local-dev.mjs",
    "backend:run": "node ./scripts/run-backend-local.mjs",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:desktop-rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:desktop-network": "cargo test --manifest-path src-tauri/Cargo.toml -- --ignored --test-threads=1",
    "test:desktop-smoke": "cargo test --manifest-path src-tauri/Cargo.toml --test session_smoke",
    "test:backend-integration": "cd ../meeting-server && go test ./test/integration",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.1",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.3",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.3",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.5"
  }
}
